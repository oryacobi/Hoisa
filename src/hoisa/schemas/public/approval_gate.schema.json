{
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "description": "Stable actor reference without leaking channel-specific identity data.",
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "actor_type": {
          "$ref": "#/$defs/ActorType"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ActorType": {
      "description": "Kinds of actors Hoisa records in workflow history.",
      "enum": [
        "human",
        "agent",
        "service",
        "system"
      ],
      "title": "ActorType",
      "type": "string"
    },
    "ContentHash": {
      "additionalProperties": false,
      "description": "Stable content hash without embedding private content.",
      "properties": {
        "algorithm": {
          "minLength": 1,
          "title": "Algorithm",
          "type": "string"
        },
        "value": {
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "algorithm",
        "value"
      ],
      "title": "ContentHash",
      "type": "object"
    },
    "EvidenceKind": {
      "description": "Kinds of evidence Hoisa can cite without embedding raw artifacts.",
      "enum": [
        "issue",
        "plan",
        "pull_request",
        "check_run",
        "repo_file",
        "command_summary",
        "redacted_summary",
        "schema_fixture"
      ],
      "title": "EvidenceKind",
      "type": "string"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "description": "Reference to evidence with summary and redaction metadata.",
      "properties": {
        "content_hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/ContentHash"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EvidenceKind"
        },
        "public_safety": {
          "$ref": "#/$defs/PublicSafetyClass"
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "source_provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProvenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "uri": {
          "minLength": 1,
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "kind",
        "uri",
        "summary",
        "public_safety",
        "redaction_status"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "GateDecision": {
      "additionalProperties": false,
      "description": "Single-use decision recorded against an approval gate.",
      "properties": {
        "decided_at": {
          "format": "date-time",
          "title": "Decided At",
          "type": "string"
        },
        "decided_by": {
          "$ref": "#/$defs/ActorRef"
        },
        "decision": {
          "$ref": "#/$defs/GateOption"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "source_provenance": {
          "$ref": "#/$defs/SourceProvenance"
        }
      },
      "required": [
        "decision",
        "decided_by",
        "decided_at",
        "rationale",
        "source_provenance"
      ],
      "title": "GateDecision",
      "type": "object"
    },
    "GateOption": {
      "description": "Allowed human responses for a gate.",
      "enum": [
        "approve",
        "request_changes",
        "request_fresh_review",
        "defer"
      ],
      "title": "GateOption",
      "type": "string"
    },
    "GateRecommendation": {
      "description": "Hoisa's recommendation for a gate.",
      "enum": [
        "approve",
        "request_changes",
        "request_fresh_review",
        "defer"
      ],
      "title": "GateRecommendation",
      "type": "string"
    },
    "GateStatus": {
      "description": "Lifecycle state for an approval gate.",
      "enum": [
        "waiting",
        "approved",
        "changes_requested",
        "review_requested",
        "deferred",
        "expired"
      ],
      "title": "GateStatus",
      "type": "string"
    },
    "GateType": {
      "description": "Kinds of human decisions Hoisa can request.",
      "enum": [
        "plan_approval",
        "privileged_action",
        "scope_change",
        "merge_readiness"
      ],
      "title": "GateType",
      "type": "string"
    },
    "PublicSafetyClass": {
      "description": "Classification for records crossing public or review boundaries.",
      "enum": [
        "public",
        "public_safe_sample",
        "redacted",
        "private_reference"
      ],
      "title": "PublicSafetyClass",
      "type": "string"
    },
    "RedactionStatus": {
      "description": "Whether a record or reference has been redacted for public use.",
      "enum": [
        "not_required",
        "redacted",
        "summary_only"
      ],
      "title": "RedactionStatus",
      "type": "string"
    },
    "RiskLevel": {
      "description": "Workflow risk classification.",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "RiskLevel",
      "type": "string"
    },
    "SourceProvenance": {
      "additionalProperties": false,
      "description": "Attribution for source observations and derived records.",
      "properties": {
        "content_hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/ContentHash"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "external_updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "External Updated At"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "public_safety": {
          "$ref": "#/$defs/PublicSafetyClass",
          "default": "public"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_system": {
          "$ref": "#/$defs/SourceSystem"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Url"
        }
      },
      "required": [
        "source_system",
        "source_id",
        "observed_at"
      ],
      "title": "SourceProvenance",
      "type": "object"
    },
    "SourceSystem": {
      "description": "External or internal systems that can originate Hoisa records.",
      "enum": [
        "hoisa",
        "github",
        "human",
        "runner",
        "filesystem",
        "conversation",
        "slack"
      ],
      "title": "SourceSystem",
      "type": "string"
    },
    "WorkflowStage": {
      "description": "Workflow stages tracked by Hoisa.",
      "enum": [
        "Planning",
        "Plan Review",
        "Plan Approval",
        "Implementation",
        "Implementation Review",
        "Implemented"
      ],
      "title": "WorkflowStage",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Structured human approval object with exact authority boundaries.",
  "properties": {
    "authority_granted": {
      "minLength": 1,
      "title": "Authority Granted",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "decision": {
      "anyOf": [
        {
          "$ref": "#/$defs/GateDecision"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "decision_needed": {
      "minLength": 1,
      "title": "Decision Needed",
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "minItems": 1,
      "title": "Evidence Refs",
      "type": "array"
    },
    "gate_status": {
      "$ref": "#/$defs/GateStatus"
    },
    "gate_type": {
      "$ref": "#/$defs/GateType"
    },
    "id": {
      "pattern": "^[0-9a-fA-F]{24}$",
      "title": "Id",
      "type": "string"
    },
    "options": {
      "items": {
        "$ref": "#/$defs/GateOption"
      },
      "minItems": 1,
      "title": "Options",
      "type": "array"
    },
    "public_safety": {
      "$ref": "#/$defs/PublicSafetyClass"
    },
    "recommendation": {
      "$ref": "#/$defs/GateRecommendation"
    },
    "redaction_status": {
      "$ref": "#/$defs/RedactionStatus"
    },
    "risk": {
      "$ref": "#/$defs/RiskLevel"
    },
    "schema_version": {
      "default": 1,
      "minimum": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "source_provenance": {
      "$ref": "#/$defs/SourceProvenance"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "why_human_needed": {
      "minLength": 1,
      "title": "Why Human Needed",
      "type": "string"
    },
    "work_item_id": {
      "pattern": "^[0-9a-fA-F]{24}$",
      "title": "Work Item Id",
      "type": "string"
    },
    "workflow_stage": {
      "$ref": "#/$defs/WorkflowStage"
    }
  },
  "required": [
    "created_at",
    "updated_at",
    "gate_type",
    "gate_status",
    "work_item_id",
    "workflow_stage",
    "risk",
    "recommendation",
    "decision_needed",
    "why_human_needed",
    "authority_granted",
    "options",
    "evidence_refs",
    "source_provenance",
    "public_safety",
    "redaction_status"
  ],
  "title": "ApprovalGate",
  "type": "object"
}
