{
  "$defs": {
    "ContentHash": {
      "additionalProperties": false,
      "description": "Stable content hash without embedding private content.",
      "properties": {
        "algorithm": {
          "minLength": 1,
          "title": "Algorithm",
          "type": "string"
        },
        "value": {
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "algorithm",
        "value"
      ],
      "title": "ContentHash",
      "type": "object"
    },
    "EvidenceKind": {
      "description": "Kinds of evidence Hoisa can cite without embedding raw artifacts.",
      "enum": [
        "issue",
        "plan",
        "pull_request",
        "check_run",
        "repo_file",
        "command_summary",
        "redacted_summary",
        "schema_fixture"
      ],
      "title": "EvidenceKind",
      "type": "string"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "description": "Reference to evidence with summary and redaction metadata.",
      "properties": {
        "content_hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/ContentHash"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EvidenceKind"
        },
        "public_safety": {
          "$ref": "#/$defs/PublicSafetyClass"
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "source_provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceProvenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "uri": {
          "minLength": 1,
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "kind",
        "uri",
        "summary",
        "public_safety",
        "redaction_status"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "ProjectRef": {
      "additionalProperties": false,
      "description": "Stable reference to a Hoisa project.",
      "properties": {
        "id": {
          "pattern": "^[0-9a-fA-F]{24}$",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "title": "ProjectRef",
      "type": "object"
    },
    "PublicSafetyClass": {
      "description": "Classification for records crossing public or review boundaries.",
      "enum": [
        "public",
        "public_safe_sample",
        "redacted",
        "private_reference"
      ],
      "title": "PublicSafetyClass",
      "type": "string"
    },
    "QueueStatus": {
      "description": "Queue ownership status for a work item.",
      "enum": [
        "Todo",
        "In Progress",
        "Done",
        "Blocked"
      ],
      "title": "QueueStatus",
      "type": "string"
    },
    "RedactionStatus": {
      "description": "Whether a record or reference has been redacted for public use.",
      "enum": [
        "not_required",
        "redacted",
        "summary_only"
      ],
      "title": "RedactionStatus",
      "type": "string"
    },
    "RepositoryProvider": {
      "description": "Repository host or source provider.",
      "enum": [
        "generic_git",
        "github"
      ],
      "title": "RepositoryProvider",
      "type": "string"
    },
    "RepositoryVisibility": {
      "description": "Visibility classification for target repository references.",
      "enum": [
        "public",
        "private",
        "internal"
      ],
      "title": "RepositoryVisibility",
      "type": "string"
    },
    "ReviewRoute": {
      "description": "Independent review route for plans and implementations.",
      "enum": [
        "Human Only",
        "Review Plan",
        "Review Implementation",
        "Review Both"
      ],
      "title": "ReviewRoute",
      "type": "string"
    },
    "RiskLevel": {
      "description": "Workflow risk classification.",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "RiskLevel",
      "type": "string"
    },
    "SourceProvenance": {
      "additionalProperties": false,
      "description": "Attribution for source observations and derived records.",
      "properties": {
        "content_hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/ContentHash"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "external_updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "External Updated At"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "public_safety": {
          "$ref": "#/$defs/PublicSafetyClass",
          "default": "public"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_system": {
          "$ref": "#/$defs/SourceSystem"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Url"
        }
      },
      "required": [
        "source_system",
        "source_id",
        "observed_at"
      ],
      "title": "SourceProvenance",
      "type": "object"
    },
    "SourceSystem": {
      "description": "External or internal systems that can originate Hoisa records.",
      "enum": [
        "hoisa",
        "github",
        "human",
        "runner",
        "filesystem",
        "conversation",
        "slack"
      ],
      "title": "SourceSystem",
      "type": "string"
    },
    "TargetRepoRef": {
      "additionalProperties": false,
      "description": "Generic repository reference without local paths or access details.",
      "properties": {
        "id": {
          "pattern": "^[0-9a-fA-F]{24}$",
          "title": "Id",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "owner": {
          "minLength": 1,
          "title": "Owner",
          "type": "string"
        },
        "project": {
          "$ref": "#/$defs/ProjectRef"
        },
        "provider": {
          "$ref": "#/$defs/RepositoryProvider"
        },
        "visibility": {
          "$ref": "#/$defs/RepositoryVisibility"
        }
      },
      "required": [
        "id",
        "provider",
        "owner",
        "name",
        "visibility",
        "project"
      ],
      "title": "TargetRepoRef",
      "type": "object"
    },
    "TrackerIssueRef": {
      "additionalProperties": false,
      "description": "Public-safe reference to a tracker issue.",
      "properties": {
        "issue_number": {
          "minimum": 1,
          "title": "Issue Number",
          "type": "integer"
        },
        "provider": {
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "tracker_issue_id": {
          "minLength": 1,
          "title": "Tracker Issue Id",
          "type": "string"
        },
        "url": {
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "tracker_issue_id",
        "provider",
        "issue_number",
        "title",
        "url"
      ],
      "title": "TrackerIssueRef",
      "type": "object"
    },
    "WorkItemType": {
      "description": "High-level tracker issue type.",
      "enum": [
        "task",
        "spike"
      ],
      "title": "WorkItemType",
      "type": "string"
    },
    "WorkflowStage": {
      "description": "Workflow stages tracked by Hoisa.",
      "enum": [
        "Planning",
        "Plan Review",
        "Plan Approval",
        "Implementation",
        "Implementation Review",
        "Implemented"
      ],
      "title": "WorkflowStage",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Agent-ready unit of Hoisa workflow.",
  "properties": {
    "blocker_summaries": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Blocker Summaries",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "goal": {
      "minLength": 1,
      "title": "Goal",
      "type": "string"
    },
    "id": {
      "pattern": "^[0-9a-fA-F]{24}$",
      "title": "Id",
      "type": "string"
    },
    "item_type": {
      "$ref": "#/$defs/WorkItemType"
    },
    "plan_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Plan Ref"
    },
    "public_safety": {
      "$ref": "#/$defs/PublicSafetyClass"
    },
    "pull_request_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pull Request Ref"
    },
    "quality_status": {
      "minLength": 1,
      "title": "Quality Status",
      "type": "string"
    },
    "redaction_status": {
      "$ref": "#/$defs/RedactionStatus"
    },
    "review_route": {
      "$ref": "#/$defs/ReviewRoute"
    },
    "risk": {
      "$ref": "#/$defs/RiskLevel"
    },
    "schema_version": {
      "default": 1,
      "minimum": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "source_provenance": {
      "$ref": "#/$defs/SourceProvenance"
    },
    "status": {
      "$ref": "#/$defs/QueueStatus"
    },
    "target_repo": {
      "$ref": "#/$defs/TargetRepoRef"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "tracker_issue": {
      "anyOf": [
        {
          "$ref": "#/$defs/TrackerIssueRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "workflow_stage": {
      "$ref": "#/$defs/WorkflowStage"
    }
  },
  "required": [
    "created_at",
    "updated_at",
    "item_type",
    "title",
    "goal",
    "target_repo",
    "workflow_stage",
    "status",
    "review_route",
    "risk",
    "quality_status",
    "source_provenance",
    "public_safety",
    "redaction_status"
  ],
  "title": "WorkItem",
  "type": "object"
}
