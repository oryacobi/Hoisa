# Copy this file to deploy/local/.env and replace the placeholder credentials.
# deploy/local/.env is intentionally ignored.

HOISA_MONGO_IMAGE=mongo:8.0
HOISA_MONGO_BIND_HOST=127.0.0.1
HOISA_MONGO_PORT=27017
HOISA_MONGO_DATABASE=hoisa

# Local placeholders only. Do not reuse these values for a real local database.
HOISA_MONGO_ROOT_USERNAME=change-me-local-admin
HOISA_MONGO_ROOT_PASSWORD=change-me-local-password
